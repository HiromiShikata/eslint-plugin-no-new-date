{
  "name": "eslint-plugin-no-new-date",
  "version": "1.0.0",
  "description": "ESLint plugin that disallows the use of new Date() to enforce timezone-aware date handling",
  "main": "dist/index.js",
  "scripts": {
    "prettier": "prettier --write '**/*'",
    "lint": "eslint src",
    "lint-fix": "eslint src --fix",
    "fmt": "npm run prettier && npm run lint-fix",
    "build": "tsc -p ./tsconfig.build.json",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HiromiShikata/eslint-plugin-no-new-date.git"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "no-new-date",
    "date",
    "timezone"
  ],
  "author": "HiromiShikata",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/HiromiShikata/eslint-plugin-no-new-date/issues"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/git"
    ],
    "branches": [
      "main"
    ]
  },
  "homepage": "https://github.com/HiromiShikata/eslint-plugin-no-new-date#readme",
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@types/eslint": "^8.56.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^5.61.0",
    "@typescript-eslint/parser": "^5.61.0",
    "check-node-version": "^4.2.1",
    "commitlint": "^21.0.0",
    "conventional-changelog-conventionalcommits": "^9.0.0",
    "eslint": "^8.44.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-no-type-assertion": "^1.3.0",
    "eslint-plugin-unused-imports": "^2.0.0",
    "jest": "^30.0.0",
    "jest-html-reporter": "^4.0.0",
    "jest-junit": "^17.0.0",
    "prettier": "^3.0.0",
    "semantic-release": "^25.0.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.1.6"
  }
}
